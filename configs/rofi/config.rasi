configuration {
   modi: "drun,run,window";
   font: "JetBrains Mono 12";
   show-icons: true;
   icon-theme: "Papirus";
   drun-display-format: "{name}";
   display-drun: "Apps";
   display-run: "Run";
   display-window: "Windows";
}
 
//@theme "~/.config/rofi/theme.rasi"

@theme "/usr/share/rofi/themes/material.rasi"
